{
  "name": "trellis-agent-toolkit",
  "version": "0.1.0",
  "private": false,
  "description": "Dependency-free, repository-local governance and verification toolkit for AI coding agents.",
  "license": "MIT",
  "author": "Farzin",
  "type": "module",
  "bin": {
    "trellis": "./.trellis/cli.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Farzin312/trellis.git"
  },
  "homepage": "https://github.com/Farzin312/trellis#readme",
  "bugs": {
    "url": "https://github.com/Farzin312/trellis/issues"
  },
  "keywords": [
    "ai-agents",
    "agent-skills",
    "developer-tools",
    "spec-driven-development",
    "verification"
  ],
  "files": [
    ".agents/",
    ".bounds/",
    ".env.example",
    ".github/copilot-instructions.md",
    ".github/workflows/ci.yml",
    ".specify/",
    ".trellis/",
    "AGENTS.md",
    "CLAUDE.md",
    "LICENSE",
    "README.md",
    "docs/"
  ],
  "scripts": {
    "init": "bash .trellis/init.sh",
    "lint": "npm run check",
    "test:self": "node --test .trellis/tests/*.test.mjs",
    "test": "node .trellis/scripts/run-evals.mjs",
    "check": "npm run check:mandates && npm run skills:health && npm run docs:check && npm run check:agnostic && npm run check:ponytail && npm run check:migrations && npm run handoffs:validate && npm run check:integrations && npm test",
    "docs:sync": "node .trellis/scripts/docs-sync.mjs",
    "docs:check": "node .trellis/scripts/docs-sync.mjs --check",
    "check:mandates": "node .trellis/scripts/check-mandate-sync.mjs",
    "check:agnostic": "node .trellis/scripts/check-agnostic.mjs",
    "check:ponytail": "node .trellis/scripts/check-ponytail.mjs",
    "check:migrations": "node .trellis/scripts/check-migration-safety.mjs",
    "check:integrations": "node .trellis/scripts/check-integrations.mjs",
    "eval": "node .trellis/scripts/run-evals.mjs",
    "metrics": "node .trellis/scripts/metrics.mjs",
    "evolve": "node .trellis/scripts/adapt-to-project.mjs",
    "handoffs:validate": "node .trellis/scripts/handoff-engine.mjs validate",
    "handoffs:list": "node .trellis/scripts/handoff-engine.mjs list",
    "skills:generate": "node .trellis/scripts/generate-skills.mjs",
    "skills:health": "node .trellis/scripts/evolve-skills.mjs",
    "services:start": "node .trellis/scripts/services.mjs start all",
    "services:stop": "node .trellis/scripts/services.mjs stop all",
    "services:status": "node .trellis/scripts/services.mjs status"
  },
  "dependencies": {},
  "devDependencies": {}
}
