{
  "name": "trellis-agent-toolkit",
  "version": "0.1.0",
  "private": false,
  "description": "Dependency-free, repository-local governance and verification toolkit for AI coding agents.",
  "license": "MIT",
  "author": "Farzin",
  "type": "module",
  "bin": {
    "trellis": "./.trellis/cli.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Farzin312/trellis.git"
  },
  "homepage": "https://github.com/Farzin312/trellis#readme",
  "bugs": {
    "url": "https://github.com/Farzin312/trellis/issues"
  },
  "keywords": [
    "ai-agents",
    "agent-skills",
    "developer-tools",
    "spec-driven-development",
    "verification"
  ],
  "files": [
    ".agents/",
    ".env.example",
    ".gitattributes",
    ".github/workflows/ci.yml",
    ".specify/memory/",
    ".specify/templates/",
    ".trellis/LICENSE",
    ".trellis/cli.mjs",
    ".trellis/init.sh",
    ".trellis/scaffold/",
    ".trellis/scripts/",
    ".trellis/services/",
    ".trellis/tests/adapt.test.mjs",
    ".trellis/tests/agnostic.test.mjs",
    ".trellis/tests/ci.test.mjs",
    ".trellis/tests/cli.test.mjs",
    ".trellis/tests/config.test.mjs",
    ".trellis/tests/docs.test.mjs",
    ".trellis/tests/evals.test.mjs",
    ".trellis/tests/init.test.mjs",
    ".trellis/tests/integrations.test.mjs",
    ".trellis/tests/mandate.test.mjs",
    ".trellis/tests/metrics.test.mjs",
    ".trellis/tests/migrations.test.mjs",
    ".trellis/tests/repo-map.test.mjs",
    ".trellis/tests/sdd-skills.test.mjs",
    ".trellis/tests/services.test.mjs",
    ".trellis/tests/skills.test.mjs",
    ".trellis/tests/wizard.test.mjs",
    "AGENTS.md",
    "CLAUDE.md",
    "LICENSE",
    "README.md",
    "SECURITY.md",
    "CHANGELOG.md",
    "docs/_subsystem-template.md",
    "docs/adopting-existing-projects.md",
    "docs/bug-fixes/README.md",
    "docs/bug-fixes/_template.md",
    "docs/coding-standards.md",
    "docs/contributing.md",
    "docs/credits.md",
    "docs/DESIGN.md",
    "docs/evals.md",
    "docs/evolution.md",
    "docs/language-support.md",
    "docs/metrics.md",
    "docs/README-FOR-AGENTS.md",
    "docs/README.md",
    "docs/repository-mapping.md",
    "docs/sdd/sdd.md",
    "docs/self-hosted-services.md",
    "docs/skills.md",
    "docs/STRUCTURE.md",
    "docs/SYSTEM.md",
    "docs/systems/README.md",
    "docs/systems/control-plane/README.md",
    "docs/systems/guidance/README.md",
    "docs/systems/verification/README.md"
  ],
  "scripts": {
    "test:self": "node --test .trellis/tests/*.test.mjs",
    "test": "node .trellis/scripts/run-evals.mjs",
    "check": "npm run check:mandates && npm run skills:health && npm run docs:check && npm run check:agnostic && npm run check:migrations && npm run check:integrations && npm test",
    "docs:check": "node .trellis/scripts/check-docs.mjs",
    "check:mandates": "node .trellis/scripts/check-mandate-sync.mjs",
    "check:agnostic": "node .trellis/scripts/check-agnostic.mjs",
    "check:migrations": "node .trellis/scripts/check-migration-safety.mjs",
    "check:integrations": "node .trellis/scripts/check-integrations.mjs",
    "skills:generate": "node .trellis/scripts/generate-skills.mjs",
    "skills:health": "node .trellis/scripts/evolve-skills.mjs"
  },
  "dependencies": {},
  "devDependencies": {}
}
