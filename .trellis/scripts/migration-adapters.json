{
  "schema_version": 1,
  "purpose": "Conservative detection metadata for Trellis filename/version and raw-SQL warning checks. This is not migration execution support.",
  "adapters": {
    "supabase": {
      "displayName": "Supabase CLI",
      "detect": { "dirs": ["supabase/migrations"], "filePattern": "*.sql", "configMarkers": ["supabase/config.toml"] },
      "versionPattern": "^(\\d{14})",
      "rlsCheckable": true
    },
    "prisma": {
      "displayName": "Prisma Migrate",
      "detect": { "dirs": ["prisma/migrations"], "filePattern": "*/migration.sql", "configMarkers": ["prisma/schema.prisma", "prisma/migrations/migration_lock.toml"] },
      "versionPattern": "^(\\d{14})",
      "versionFromParent": true,
      "rlsCheckable": false
    },
    "drizzle": {
      "displayName": "Drizzle Kit",
      "detect": { "dirs": ["drizzle", "migrations"], "filePattern": "*.sql", "configMarkers": ["drizzle.config.ts", "drizzle.config.json", "drizzle/meta/_journal.json"] },
      "versionPattern": "^(\\d+)",
      "rlsCheckable": true
    },
    "flyway": {
      "displayName": "Flyway",
      "detect": { "dirs": ["db/migration", "src/main/resources/db/migration"], "filePattern": "V*__*.sql", "configMarkers": ["flyway.toml", "flyway.conf"] },
      "versionPattern": "^V(\\d+[._\\d]*)",
      "rlsCheckable": true
    },
    "alembic": {
      "displayName": "Alembic",
      "detect": { "dirs": ["alembic/versions", "migrations/versions"], "filePattern": "*.py", "configMarkers": ["alembic.ini", "alembic/env.py"] },
      "versionPattern": "^([a-f0-9]{12})",
      "rlsCheckable": false
    },
    "rails": {
      "displayName": "Rails Active Record",
      "detect": { "dirs": ["db/migrate"], "filePattern": "*.rb", "configMarkers": ["config/database.yml", "db/schema.rb", "db/structure.sql"] },
      "versionPattern": "^(\\d{14})",
      "rlsCheckable": false
    },
    "django": {
      "displayName": "Django Migrations",
      "detect": { "dirs": ["migrations"], "filePattern": "*.py", "configMarkers": ["manage.py"] },
      "versionPattern": "^(\\d{4})",
      "rlsCheckable": false
    },
    "knex": {
      "displayName": "Knex.js",
      "detect": { "dirs": ["migrations", "db/migrations"], "filePattern": "*.js", "configMarkers": ["knexfile.js", "knexfile.ts", "knexfile.cjs"] },
      "versionPattern": "^(\\d{14})",
      "rlsCheckable": false
    },
    "golang-migrate": {
      "displayName": "golang-migrate",
      "detect": { "dirs": ["migrations", "db/migrations"], "filePattern": "*_up.sql", "configMarkers": [] },
      "versionPattern": "^(\\d+)",
      "rlsCheckable": true
    },
    "typeorm": {
      "displayName": "TypeORM",
      "detect": { "dirs": ["migrations", "src/migrations"], "filePattern": "*.ts", "configMarkers": ["data-source.ts"] },
      "versionPattern": "^(\\d+)",
      "rlsCheckable": false
    },
    "goose": {
      "displayName": "Goose",
      "detect": { "dirs": ["migrations", "db/migrations"], "filePattern": "*.sql", "configMarkers": [] },
      "versionPattern": "^(\\d+)",
      "rlsCheckable": true
    },
    "atlas": {
      "displayName": "Atlas",
      "detect": { "dirs": ["migrations"], "filePattern": "*.sql", "configMarkers": ["atlas.hcl", "migrations/atlas.sum"] },
      "versionPattern": "^(\\d{14})",
      "rlsCheckable": true
    },
    "sequelize": {
      "displayName": "Sequelize",
      "detect": { "dirs": ["migrations"], "filePattern": "*.js", "configMarkers": [".sequelizerc", "config/config.json"] },
      "versionPattern": "^(\\d{14})",
      "rlsCheckable": false
    },
    "node-pg-migrate": {
      "displayName": "node-pg-migrate",
      "detect": { "dirs": ["migrations"], "filePattern": "*.js", "configMarkers": ["package.json"] },
      "versionPattern": "^(\\d+)",
      "rlsCheckable": true
    },
    "liquibase": {
      "displayName": "Liquibase",
      "detect": { "dirs": ["db/changelog", "src/main/resources/db/changelog"], "filePattern": "*.xml", "configMarkers": ["liquibase.properties", "db.changelog-master.xml", "db.changelog-master.yaml"] },
      "versionPattern": "^([a-f0-9]+-)",
      "rlsCheckable": false
    }
  }
}
