{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "reporters": ["html", "clear-text", "progress"],
  "testRunner": "vitest",
  "coverageAnalysis": "perTest",
  "mutate": [
    "lib/**/*.ts",
    "app/**/*.ts",
    "!lib/**/*.test.ts",
    "!app/**/*.test.ts",
    "!**/*.spec.*"
  ],
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 50
  },
  "timeoutMS": 5000,
  "concurrency": 4,
  "ignoreStatic": true
}
