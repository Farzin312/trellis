# Environment Variables
#
# This is a TEMPLATE. Copy to .env.local and fill in real values.
# .env.local is the single source of truth (gitignored, never committed).
#
# Pattern: suffix every key with _DEV / _STAGING / _PROD for per-environment isolation.
# Read all env vars through centralized helpers (lib/env.ts), never process.env directly.

# ── App ──────────────────────────────────────────────
APP_ENV=dev                          # dev | staging | prod
NEXT_PUBLIC_APP_ENV=dev

# ── Database (example: Supabase) ─────────────────────
NEXT_PUBLIC_SUPABASE_URL_DEV=
NEXT_PUBLIC_SUPABASE_ANON_KEY_DEV=
SUPABASE_SERVICE_ROLE_KEY_DEV=

# ── Auth (example: Supabase Auth) ────────────────────
# Auth truth is your auth provider. No alternative auth source permitted.

# ── Payments (example: Stripe) ───────────────────────
# Payment truth is Stripe webhooks. Per-env account isolation mandatory.
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY_DEV=
# STRIPE_SECRET_KEY_DEV=

# ── Observability (Tier 3: Arize Phoenix) ────────────
# Self-hosted via: docker compose -f docker-compose.phoenix.yml up -d
# See docs/self-hosted-services.md for prerequisites
# PHOENIX_SERVER_URL=http://localhost:6006
# PHOENIX_API_KEY=

# ── Agent Memory (Optional upgrade: Mem0) ────────────
# Self-hosted via: docker compose -f docker-compose.mem0.yml up -d
# See docs/self-hosted-services.md for prerequisites (Docker + LLM)
# Dashboard: http://localhost:8228
# MEM0_API_URL=http://localhost:8228
# MEM0_API_KEY=
# MEM0_PORT=8228
# Mem0 LLM provider (choose one):
# OPENAI_API_KEY=
# Or for Ollama (local): uncomment OLLAMA_API_BASE in docker-compose.mem0.yml
