# Environment Variables
#
# This is a TEMPLATE. Copy to .env.local and fill in real values.
# .env.local is the single source of truth (gitignored, never committed).
#
# Pattern: suffix every key with _DEV / _STAGING / _PROD for per-environment isolation.
# Read all env vars through centralized helpers, never process.env directly.

# ── App ──────────────────────────────────────────────
APP_ENV=dev                          # dev | staging | prod

# ── Database ─────────────────────────────────────────
# Example: Supabase — see .trellis/templates/js-ts/env.example for the full block
# DATABASE_URL_DEV=

# ── Auth ─────────────────────────────────────────────
# Auth truth is your auth provider. No alternative auth source permitted.

# ── Payments ─────────────────────────────────────────
# Payment truth is your payment provider's webhooks. Per-env account isolation mandatory.

# ── Observability (Tier 3: Arize Phoenix) ────────────
# Self-hosted via: npm run services:start
# See docs/self-hosted-services.md and docs/metrics.md for prerequisites
# PHOENIX_SERVER_URL=http://localhost:6006
# PHOENIX_API_KEY=
#
# Claude Code native OTel export (enables full agent traces in Phoenix):
# CLAUDE_CODE_ENABLE_TELEMETRY=1
# OTEL_METRICS_EXPORTER=otlp
# OTEL_LOGS_EXPORTER=otlp
# OTEL_EXPORTER_OTLP_PROTOCOL=grpc
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ── Agent Memory (Optional upgrade: Mem0) ────────────
# Not vendored by Trellis. Simplest: `pip install mem0ai` (in-process, no server).
# Server mode: mem0's own stack — `git clone mem0ai/mem0 && cd server && make bootstrap`
# See docs/self-hosted-services.md. Only set these if running the server (mode 2):
# MEM0_API_URL=http://localhost:8888
# MEM0_API_KEY=
# LLM key for extraction (library or server mode):
# OPENAI_API_KEY=
